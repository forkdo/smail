{
	"name": "smail-web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "pnpm run build && wrangler deploy",
		"dev": "react-router dev",
		"postinstall": "pnpm run cf-typegen",
		"preview": "pnpm run build && vite preview",
		"typecheck": "pnpm run cf-typegen && react-router typegen && tsc -b",
		"format": "biome format --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply smail-database",
		"db:migrate:remote": "wrangler d1 migrations apply smail-database --remote",
		"db:list": "wrangler d1 migrations list smail-database",
		"db:reset": "wrangler d1 execute smail-database --command=\"DROP TABLE IF EXISTS attachments; DROP TABLE IF EXISTS emails; DROP TABLE IF EXISTS mailboxes; DELETE FROM d1_migrations;\"",
		"test:email": "node scripts/test-email.js",
		"test:email:custom": "node scripts/test-email.js",
		"generate-icons": "node scripts/generate-icons.cjs"
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@react-router/cloudflare": "^7.13.1",
		"@scaleway/random-name": "^5.1.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.35",
		"lucide-react": "^0.577.0",
		"nanoid": "^5.1.6",
		"postal-mime": "^2.7.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.1",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@cloudflare/vite-plugin": "^1.26.0",
		"@cloudflare/workers-types": "^4.20260305.1",
		"@react-router/dev": "^7.13.1",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.9",
		"png-to-ico": "^3.0.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.1",
		"to-ico": "^1.1.5",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1",
		"wrangler": "^4.70.0"
	}
}
